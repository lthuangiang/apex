<!-- ── Header ──────────────────────────────────────────────────────────── -->
<div class="header">
  <% if (typeof botId !== 'undefined' && botId) { %>
  <!-- Back to Manager link for bot detail pages -->
  <div style="padding: 0.5rem 1rem; border-bottom: 1px solid #1e1e1e;">
    <a href="/" style="color: #6496ff; text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.4rem;">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      Back to Manager
    </a>
  </div>
  <% } %>
  <div class="header-top">
    <div class="header-title">
      <img src="/images/logo.png" alt="DRIFT" class="header-logo"/>
      <span id="status-badge" class="status-badge status-stopped">
        <span class="dot"></span>
        <span id="status-text">STOPPED</span>
      </span>
    </div>
    <div style="display:flex;align-items:center;gap:0.75rem">
      <div style="font-size:0.72rem;color:#555;" id="updated-at"></div>
      <button class="gear-btn" onclick="openCfgModal()" title="Bot Settings">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/>
          <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
    </div>
  </div>
  <div class="header-meta"><span id="symbol-label">BTC-USD</span></div>
  <div class="wallet">WALLET: <span id="wallet-addr">—</span></div>
</div>
