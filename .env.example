# Core Wallets & Addresses
# For Decibel: Ed25519 Private Key. For SoDex: Ethereum-style Private Key (API_SECRET)
API_WALLET_PRIVATE_KEY=0x...
API_WALLET_ADDRESS=0x...
SUBACCOUNT_ADDRESS=0x...

# Decibel / Aptos Settings
# Get your node API key from Aptos Labs or your RPC provider
APTOS_NODE_API_KEY=your_aptos_bearer_token

# SoDex Settings
# Your SoDex API Key from the exchange dashboard
API_KEY=your_sodex_api_key
# Your Wallet Private Key (used for EIP-712 signing)
API_SECRET=0x...

# Telegram Notifications
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ENABLED=true                      # Set to 'false' to disable Telegram (local dev)

# APEX — AI Signal Layer
LLM_PROVIDER=openai                        # 'openai' or 'anthropic'
OPENAI_API_KEY=sk-...                      # Required if LLM_PROVIDER=openai
ANTHROPIC_API_KEY=sk-ant-...               # Required if LLM_PROVIDER=anthropic
SOSOVALUE_API_KEY=SOSO-...                 # SoSoValue API key

# APEX — Trade Logger
TRADE_LOG_BACKEND=json                     # 'json' or 'sqlite'
TRADE_LOG_PATH=./trades.json               # Path to log file or SQLite DB

# APEX — Dashboard
DASHBOARD_PORT=3000                        # Port for the web dashboard
DASHBOARD_PASSCODE=                        # Passcode to access dashboard (leave empty to disable auth)

# Trading Memory AI — service URLs (auto-set by docker-compose, override for local dev)
CHROMA_URL=http://localhost:8000           # ChromaDB vector store
OLLAMA_URL=http://localhost:11434          # Ollama local LLM

# SoDex SoPoints API
SODEX_SOPOINTS_TOKEN=                      # Bearer token for SoPoints summary API
